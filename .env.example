DATABASE_URL=sqlite:///./chat_routing.db
MODEL_PATH=training/model/svm_intent_pipeline.joblib
APP_ENV=development
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# WAHA (WhatsApp HTTP API) — match docker-compose WAHA_API_KEY
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=waha-secret-change-me
WAHA_SESSION_NAME=default
WAHA_HOOK_HMAC_KEY=waha-hmac-change-me
# On Intel/AMD hosts: WAHA_IMAGE=devlikeapro/waha:gows
# WAHA_IMAGE=devlikeapro/waha:gows-arm
